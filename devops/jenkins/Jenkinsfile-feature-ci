pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    triggers {
        // Triggered by the GitHub Actions workflow (.github/workflows/trigger-jenkins-feature-ci.yml)
        // on every push to the feature branch via Generic Webhook Trigger plugin.
        // Token must match the JENKINS_FEATURE_CI_TOKEN secret configured in GitHub.
        GenericWebhookTrigger(token: 'feature-ci-trigger')
    }

    environment {
        MAVEN_ARGS = '-B -ntp'
        MVN_CMD_WIN = 'D:/anand/work/swtools/mvn/bin/mvn.cmd'
        CODEQL_EXE_WIN = 'D:/anand/work/swtools/codeql/dist/codeql/codeql.exe'
        CODEQL_DB_DIR = 'codeql-db-user-service'
        CODEQL_SARIF = 'codeql-user-service.sarif'
        GIT_REPO_URL = 'https://github.com/anandpatil/cicd-demo.git'
        GIT_BRANCH = 'feature/devopsChanges'
    }

    stages {
        stage('Verify Toolchain') {
            steps {
                script {
                    currentBuild.displayName = "#${env.BUILD_NUMBER} feature-ci"

                    if (isUnix()) {
                        sh '''#!/bin/sh
set -eu
command -v mvn
command -v codeql
'''
                    } else {
                        bat '''@echo off
if not exist "%MVN_CMD_WIN%" exit /b 1
if exist "%CODEQL_EXE_WIN%" goto :toolchain_ok
where codeql >nul 2>nul || exit /b 1
:toolchain_ok
'''
                    }
                }
            }
        }

        stage('Checkout Source') {
            steps {
                script {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${env.GIT_BRANCH}"]],
                        doGenerateSubmoduleConfigurations: false,
                        extensions: [],
                        userRemoteConfigs: [[
                            url: env.GIT_REPO_URL,
                            credentialsId: 'github-credentials'
                        ]]
                    ])
                }
            }
        }

        stage('Unit Tests And Coverage') {
            steps {
                dir('apps/microservices/user-service') {
                    script {
                        if (isUnix()) {
                            sh "mvn ${env.MAVEN_ARGS} clean verify"
                        } else {
                            bat "\"${env.MVN_CMD_WIN}\" ${env.MAVEN_ARGS} clean verify"
                        }
                    }
                }
            }
        }

        stage('CodeQL Analysis') {
            steps {
                dir('apps/microservices/user-service') {
                    script {
                        if (isUnix()) {
                            sh '''#!/bin/sh
set -eu
command -v codeql
rm -rf "$WORKSPACE/$CODEQL_DB_DIR" "$WORKSPACE/$CODEQL_SARIF"
codeql database create "$WORKSPACE/$CODEQL_DB_DIR" --overwrite --language=java --source-root . --command "mvn -B -DskipTests=true clean compile"
# Some CodeQL versions auto-finalize during create; do not fail if already finalized.
codeql database finalize "$WORKSPACE/$CODEQL_DB_DIR" || true
codeql database analyze "$WORKSPACE/$CODEQL_DB_DIR" codeql/java-queries --download --format=sarif-latest --output "$WORKSPACE/$CODEQL_SARIF"
ERROR_COUNT=$(grep -o '"level":"error"' "$WORKSPACE/$CODEQL_SARIF" | wc -l | tr -d ' ')
echo "CodeQL error-level findings: $ERROR_COUNT"
if [ "$ERROR_COUNT" -gt 0 ]; then
  echo "Failing build due to CodeQL error-level findings"
  exit 1
fi
'''
                        } else {
                            powershell '''
$ErrorActionPreference = "Stop"
$codeqlExe = $env:CODEQL_EXE_WIN
if (-not (Test-Path $codeqlExe)) {
    $cmd = Get-Command codeql -ErrorAction SilentlyContinue
    if ($cmd) { $codeqlExe = $cmd.Source } else { $codeqlExe = $null }
}
if (-not $codeqlExe) {
    Write-Error "codeql CLI not found. Install CodeQL and add it to PATH, or install to $env:CODEQL_EXE_WIN"
    exit 1
}
Write-Output "Using CodeQL: $codeqlExe"

$dbPath = Join-Path $env:WORKSPACE $env:CODEQL_DB_DIR
$sarifPath = Join-Path $env:WORKSPACE $env:CODEQL_SARIF
if (Test-Path $dbPath) { Remove-Item -Recurse -Force $dbPath }
if (Test-Path $sarifPath) { Remove-Item -Force $sarifPath }

$buildCmd = "$env:MVN_CMD_WIN -B -DskipTests=true clean compile"
& $codeqlExe database create $dbPath --language=java --source-root . --command $buildCmd
if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Some CodeQL versions auto-finalize during create; ignore finalize failure in that case.
& $codeqlExe database finalize $dbPath *> $null

& $codeqlExe database analyze $dbPath codeql/java-queries --download --format=sarif-latest --output $sarifPath
if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

$sarifRaw = Get-Content -Raw $sarifPath
if ($sarifRaw -match '"level":"error"') {
    Write-Output "CodeQL error-level findings detected"
    exit 1
}
Write-Output "CodeQL error-level findings: 0"
'''
                        }
                    }
                }
            }
        }
    }

    post {
        failure {
            script {
                try {
                    emailext(
                        recipientProviders: [developers(), requestor()],
                        to: 'anand.dpatil@gmail.com',
                        subject: 'Build Failure: ${JOB_NAME} - #${BUILD_NUMBER}',
                        body: '''
                            <html>
                            <head>
                                <style>
                                    body { font-family: Arial, sans-serif; margin: 0; padding: 20px; }
                                    .header { background-color: #dc3545; color: white; padding: 15px; border-radius: 5px 5px 0 0; }
                                    .content { background-color: #f8f9fa; padding: 20px; border: 1px solid #dee2e6; margin-bottom: 10px; }
                                    .footer { margin-top: 20px; font-size: 12px; color: #6c757d; }
                                    .build-info { margin: 10px 0; }
                                    .btn { display: inline-block; padding: 10px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 5px; }
                                </style>
                            </head>
                            <body>
                                <div class="header">
                                    <h2>🚨 BUILD FAILURE ALERT</h2>
                                </div>
                                <div class="content">
                                    <h3>${env.JOB_NAME} - Build #${env.BUILD_NUMBER}</h3>
                                    <div class="build-info">
                                        <p><strong>Status:</strong> FAILED</p>
                                        <p><strong>Branch:</strong> ${env.GIT_BRANCH ?: 'N/A'}</p>
                                        <p><strong>Repository:</strong> ${env.GIT_URL ?: 'N/A'}</p>
                                        <p><strong>Duration:</strong> ${currentBuild.durationString}</p>
                                        <p><strong>Build Log:</strong></p>
                                        <pre>${BUILD_LOG, maxLines=50}</pre>
                                    </div>
                                    <p><a href="${env.BUILD_URL}" class="btn">View Full Build Details</a></p>
                                </div>
                                <div class="footer">
                                    <p>This is an automated alert. Please check the build logs and fix the issue.</p>
                                </div>
                            </body>
                            </html>
                        ''',
                        mimeType: 'text/html',
                        attachLog: true
                    )
                    echo "Failure notification email sent successfully to anand.dpatil@gmail.com"
                } catch (Exception e) {
                    echo "WARNING: Failed to send failure notification email: ${e.message}"
                    echo "Build failure will not be blocked due to email notification failure"
                }
            }
        }
        always {
            junit allowEmptyResults: true, testResults: 'apps/microservices/user-service/target/surefire-reports/*.xml'
            archiveArtifacts allowEmptyArchive: true, artifacts: 'apps/microservices/user-service/target/site/jacoco/**, codeql-user-service.sarif'
            cleanWs()
        }
    }
}